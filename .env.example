# ── Server ───────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Database ─────────────────────────────────────────────
# Local:
DATABASE_URL="postgresql://postgres:password@localhost:5432/scholarflow"
# Neon (add connect_timeout to handle cold-start wakeup):
# DATABASE_URL="postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require&connect_timeout=15"

# ── Auth ─────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ── Groq (AI features) ───────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── CORS (comma-separated allowed origins) ───────────────
# Leave blank in dev (defaults to http://localhost:5173)
# Production: set to your Netlify URL e.g. https://scholarflow.netlify.app
ALLOWED_ORIGINS=

# ── Client (Vite) ─────────────────────────────────────────
# Dev: leave blank — Vite proxy forwards /api → localhost:3001
# Netlify: set to your Railway URL e.g. https://scholarflow-api.up.railway.app/api
VITE_API_BASE_URL=
