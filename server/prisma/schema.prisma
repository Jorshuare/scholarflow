generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

enum Status {
  PENDING
  INCLUDED
  EXCLUDED
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  projects     Project[]
}

model Project {
  id           String        @id @default(cuid())
  userId       String
  name         String
  description  String?
  createdAt    DateTime      @default(now())
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  papers       Paper[]
  tags         Tag[]
  chatMessages ChatMessage[]
  criteria     Criterion[]
}

model Paper {
  id              String            @id @default(cuid())
  projectId       String
  title           String
  authors         String?
  year            Int?
  venue           String?
  doi             String?
  abstract        String?
  status          Status            @default(PENDING)
  exclusionReason String?
  notes           String?
  rawText         String?
  pdfProcessed    Boolean           @default(false)
  createdAt       DateTime          @default(now())
  project         Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  paperTags        PaperTag[]
  screeningResult  ScreeningResult?
  extractionResult ExtractionResult?
  chunks           PaperChunk[]
}

model Tag {
  id        String     @id @default(cuid())
  projectId String
  name      String
  colour    String     @default("#6366f1")
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  paperTags PaperTag[]
}

model PaperTag {
  paperId String
  tagId   String
  paper   Paper  @relation(fields: [paperId], references: [id], onDelete: Cascade)
  tag     Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([paperId, tagId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  projectId String
  role      String
  content   String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Criterion {
  id          String   @id @default(cuid())
  projectId   String
  type        String   // 'INCLUSION' or 'EXCLUSION'
  code        String   // 'IC1', 'IC2', 'EC1', ...
  description String
  createdAt   DateTime @default(now())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ExtractionResult {
  id           String   @id @default(cuid())
  paperId      String   @unique
  method       String?
  dataset      String?
  metric       String?
  performance  String?
  limitations  String?
  futureWork   String?
  contribution String?
  failed       Boolean  @default(false)
  extractedAt  DateTime @default(now())
  paper        Paper    @relation(fields: [paperId], references: [id], onDelete: Cascade)
}

model ScreeningResult {
  id                 String   @id @default(cuid())
  paperId            String   @unique
  recommendation     String   // 'INCLUDE' | 'EXCLUDE' | 'UNCERTAIN'
  confidence         Int
  matchedInclusion   String[]
  failedInclusion    String[]
  triggeredExclusion String[]
  reasoning          String
  humanOverride      Boolean  @default(false)
  finalDecision      String?
  processedAt        DateTime @default(now())
  paper              Paper    @relation(fields: [paperId], references: [id], onDelete: Cascade)
}

model PaperChunk {
  id         String                    @id @default(cuid())
  paperId    String                    @map("paper_id")
  projectId  String                    @map("project_id")
  chunkIndex Int                       @map("chunk_index")
  text       String
  embedding  Unsupported("vector(384)")
  createdAt  DateTime                  @default(now()) @map("created_at")

  paper      Paper                     @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@index([paperId])
  @@index([projectId])
  @@map("paper_chunks")
}
